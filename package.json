{
  "name": "undead",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "packages/*",
    "server",
    "apps/*"
  ],
  "scripts": {
    "dev:server": "npm run dev --workspace=server",
    "dev:mobile": "npm run start --workspace=apps/mobile",
    "build:shared": "npm run build --workspace=packages/shared",
    "build:server": "npm run build --workspace=server",
    "db:generate": "npm run db:generate --workspace=server",
    "db:migrate": "npm run db:migrate --workspace=server",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "postinstall": "npm run build --workspace=packages/shared",
    "android": "expo run:android",
    "ios": "expo run:ios"
  },
  "devDependencies": {
    "localtunnel": "^2.0.2",
    "typescript": "^5.6.0"
  },
  "dependencies": {
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.2",
    "expo": "~52.0.49",
    "react": "18.3.1",
    "react-native": "0.76.9"
  }
}
